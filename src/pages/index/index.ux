    margin-top: 20px; 
  }
  
  .time-container {
    margin-top: 15px; 
    height: 40px;
    align-items: center; 
  }
  .time {
    font-size: 26px; 
    margin: 0 1px;
  }
  
  .rotate-left, 
  .rotate-small-left, 
  .colon, 
  .rotate-small-right, 
  .rotate-right {
